{
  "name": "ecosage",
  "version": "1.0.0",
  "description": "AI-powered carbon footprint tracker and coach using Google Gemini and Firebase",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "lint": "eslint .",
    "test": "jest --coverage",
    "test:e2e": "playwright test",
    "test:all": "npm run lint && npm test && npm run test:e2e"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "firebase-admin": "^12.1.0",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "eslint": "^9.3.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 10000,
    "testMatch": ["**/*.test.js"],
    "testPathIgnorePatterns": ["/node_modules/", "/e2e/"],
    "collectCoverageFrom": [
      "server.js",
      "routes/**/*.js",
      "services/**/*.js",
      "middleware/**/*.js",
      "data/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 85
      }
    }
  }
}
